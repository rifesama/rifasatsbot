{
  "name": "lottery-lightning-bot",
  "version": "1.0.0",
  "description": "Bot de lotería con Lightning Network",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build"
  },
  "dependencies": {
    "telegraf": "^4.15.0",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "qrcode": "^1.5.3",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/qrcode": "^1.5.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
